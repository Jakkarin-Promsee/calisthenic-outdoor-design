# Ignore everything by default
*

# Allow directories to be traversed
!*/

# Allow markdown docs only
!*.md

# Allow design images + PDF (deliverable sets: final1-th/ Thai source · final1-en/ English)
!final1-*/design/images/
!final1-*/design/images/**

!final1-*/design/*.pdf

# Allow Blender piece files — .blend1 auto-backups stay ignored
!models/final1-blender/
!models/final1-blender/*.blend
!models/archive/
!models/archive/*.blend

# Allow this file
!.gitignore

# Renders are git-ignored (stills, animation, ~2.6 GB raw frames + a stray embedded
# git repo under _frames/). Keep the whole tree out — anchored so !*/ can't re-traverse it.
/renders/
